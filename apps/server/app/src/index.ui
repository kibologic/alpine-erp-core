import { SwissApp } from '@kibologic/core';
import { Shell } from '@kibologic/shell/host/src/Shell.uix';
import { boot } from '@kibologic/shell/host/src/boot.ui';
import { can, canAny, canAll } from '@kibologic/shell/host/src/permissions.ui';
import { register } from './register.ui';
import { LoginPage } from './auth/LoginPage.uix';
import { SignupPage } from './auth/SignupPage.uix';
import { ForgotPasswordPage } from './auth/ForgotPasswordPage.uix';
import { ResetPasswordPage } from './auth/ResetPasswordPage.uix';
import { OrgSelectPage } from './auth/OrgSelectPage.uix';
import { PendingInvitesPage } from './auth/PendingInvitesPage.uix';

async function main() {
  const container = document.getElementById('shell-root');
  if (!container) {
    console.error('[Alpine] #shell-root not found');
    return;
  }

  const path = window.location.pathname;
  const token = localStorage.getItem('alpine-auth-token');

  // Public auth routes
  if (path === '/login') {
    if (token) {
      window.location.href = '/';
      return;
    }
    SwissApp.mount(LoginPage, container, {
      onNavigate: (page: string) => {
        if (page === 'signup') window.location.href = '/signup';
        else if (page === 'forgot-password') window.location.href = '/forgot-password';
      },
    });
    return;
  }

  if (path === '/signup') {
    if (token) {
      window.location.href = '/';
      return;
    }
    SwissApp.mount(SignupPage, container, {
      onNavigate: (page: string) => {
        if (page === 'login') window.location.href = '/login';
      },
    });
    return;
  }

  if (path === '/forgot-password') {
    SwissApp.mount(ForgotPasswordPage, container, {
      onNavigate: (page: string) => {
        if (page === 'login') window.location.href = '/login';
      },
    });
    return;
  }

  if (path === '/reset-password') {
    SwissApp.mount(ResetPasswordPage, container, {
      onNavigate: (page: string) => {
        if (page === 'login') window.location.href = '/login';
      },
    });
    return;
  }

  // App routes — require auth
  if (!token) {
    window.location.href = '/login';
    return;
  }

  // Check for pending invites
  const pendingInvites = JSON.parse(localStorage.getItem('alpine-pending-invites') || '[]');
  if (pendingInvites.length > 0) {
    SwissApp.mount(PendingInvitesPage, container);
    return;
  }

  // Check tenant selection
  const tenantId = localStorage.getItem('alpine-tenant-id');

  if (!tenantId) {
    const tenantsRaw = localStorage.getItem('alpine-tenants');
    const tenants = tenantsRaw ? JSON.parse(tenantsRaw) : [];

    if (tenants.length === 1) {
      // Auto-select the only tenant
      localStorage.setItem('alpine-tenant-id', tenants[0].tenant_id);
    } else if (tenants.length > 1) {
      // Show org selection page
      SwissApp.mount(OrgSelectPage, container, {
        onNavigate: (page: string) => {
          if (page === 'login') window.location.href = '/login';
        },
      });
      return;
    } else {
      // No tenants — go to login
      window.location.href = '/login';
      return;
    }
  }

  await boot();
  // Wire permissions helpers onto __skltn so any component can call
  // window.__skltn.can('some.atom') and get a real boolean back.
  if (window.__skltn) {
    window.__skltn.can = can;
    window.__skltn.canAny = canAny;
    window.__skltn.canAll = canAll;
  }
  await register();
  SwissApp.mount(Shell, container);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', main);
} else {
  main();
}
