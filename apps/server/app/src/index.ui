import { SwissApp } from '@swissjs/core';
import { Shell } from '@skltn/shell/host/src/Shell.uix';
import { boot } from '@skltn/shell/host/src/boot.ui';
import { register } from './register.ui';

async function main() {
  const container = document.getElementById('shell-root');
  if (!container) {
    console.error('[Alpine] #shell-root not found');
    return;
  }
  await boot();
  await register();
  SwissApp.mount(Shell, container);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', main);
} else {
  main();
}
