import { SwissComponent } from '@kibologic/core';

component OrgSelectPage {
  props = {
    onNavigate: Function,
  };

  state { let orgs: any[] = []; }
  state { let loading: boolean = true; }

  async mounted() {
    try {
      const raw = localStorage.getItem('alpine-tenants');
      const tenants = raw ? JSON.parse(raw) : [];

      const resolved = [];
      for (const t of tenants) {
        try {
          const token = localStorage.getItem('alpine-auth-token') || '';
          const res = await fetch(`/api/v1/tenant/${t.tenant_id}/config`, {
            headers: {
              'Authorization': `Bearer ${token}`,
              'X-Internal-Token': '',
            },
          });
          if (res.ok) {
            const data = await res.json();
            resolved.push({
              id: t.tenant_id,
              name: data.name || t.tenant_id,
              role: t.role,
              initial: (data.name || 'O')[0].toUpperCase(),
            });
          } else {
            resolved.push({ id: t.tenant_id, name: t.tenant_id, role: t.role, initial: '?' });
          }
        } catch {
          resolved.push({ id: t.tenant_id, name: t.tenant_id, role: t.role, initial: '?' });
        }
      }

      this.orgs = resolved;
    } catch {
      this.orgs = [];
    }
    this.loading = false;
    this.scheduleUpdate?.();
  }

  selectOrg(tenantId: string) {
    localStorage.setItem('alpine-tenant-id', tenantId);
    window.location.href = '/';
  }

  signOut() {
    localStorage.removeItem('alpine-auth-token');
    localStorage.removeItem('alpine-tenant-id');
    localStorage.removeItem('alpine-user');
    localStorage.removeItem('alpine-tenants');
    this.props.onNavigate('login');
  }

  render() {
    return (
      <div class="auth-page">
        <div class="auth-card">
          <div class="auth-logo" style="margin-bottom:2rem;">
            <span class="auth-logo-icon">⛰</span>
            <span class="auth-logo-text">Alpine ERP</span>
          </div>
          <h1 class="auth-title" style="margin-bottom:6px;">Select organisation</h1>
          <p class="auth-subtitle" style="margin-bottom:1.5rem;">Choose which workspace to open</p>

          {this.loading ? (
            <div style="padding:2rem;text-align:center;color:var(--color-text-muted);">Loading…</div>
          ) : (
            <div class="org-list">
              {this.orgs.length === 0 ? (
                <p style="text-align:center;color:var(--color-text-muted);padding:2rem 0;">No organisations found.</p>
              ) : (
                this.orgs.map((org: any) => (
                  <button class="org-item" type="button" onClick={() => this.selectOrg(org.id)}>
                    <div class="org-item-avatar">{org.initial}</div>
                    <div class="org-item-info">
                      <div class="org-item-name">{org.name}</div>
                      <div class="org-item-role">{org.role}</div>
                    </div>
                    <span class="org-item-arrow">→</span>
                  </button>
                ))
              )}
            </div>
          )}

          <p class="auth-switch" style="margin-top:1.5rem;">
            <a href="#" class="auth-link" onClick={(e) => { e.preventDefault(); this.signOut(); }}>
              Sign out
            </a>
          </p>
        </div>
      </div>
    );
  }
}
