export type UserRole = 'admin' | 'manager' | 'cashier'

export type UserStatus = 'active' | 'inactive'

export interface User {
  id: string
  email: string
  firstName: string
  lastName: string
  role: UserRole
  status: UserStatus
  createdAt: string
  lastLogin?: string
}

export interface CreateUserDto {
  email: string
  firstName: string
  lastName: string
  role: UserRole
}

export interface UpdateUserDto {
  email?: string
  firstName?: string
  lastName?: string
  role?: UserRole
  status?: UserStatus
}

export interface UserListResponse {
  users: User[]
  total: number
  limit: number
}
