import { registerModule, loadModuleTranslations } from '@alpine/core';
import { enInventory } from './locales/en.ui';

const inventorySvg = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`

registerModule({
  id: 'inventory',
  name: 'Inventory',
  icon: inventorySvg,
  tier: 'free',
  sections: [
    { id: 'items', label: 'Items', page: 'InventoryItemsPage' },
    { id: 'stock-levels', label: 'Stock Levels', page: 'StockLevelsPage' },
    { id: 'stock-take', label: 'Stock Take', page: 'StockTakePage' },
    { id: 'movements', label: 'Stock Movements', page: 'StockMovementsPage' },
    { id: 'categories', label: 'Categories', page: 'InventoryCategoriesPage' },
    { id: 'suppliers', label: 'Suppliers', page: 'SuppliersPage' },
    { id: 'reports', label: 'Reports', page: 'InventoryReportsPage' },
    { id: 'settings', label: 'Settings', page: 'InventorySettingsPage' },
  ],
  actions: [
    { atom: 'inventory.view', label: 'View Inventory', description: 'View products and stock levels' },
    { atom: 'inventory.adjust', label: 'Adjust Stock', description: 'Adjust stock quantities' },
    { atom: 'inventory.manage', label: 'Manage Products', description: 'Create, edit, delete products' },
    { atom: 'inventory.export', label: 'Export Data', description: 'Export inventory data' },
    { atom: 'inventory.stock_take', label: 'Stock Take', description: 'Perform stock take operations' },
    { atom: 'inventory.view_movements', label: 'View Movements', description: 'View stock movement history' },
  ],
  async register(app) {
    console.log('[Alpine] Inventory module registered');
    loadModuleTranslations('en-US', 'inventory', enInventory);
    loadModuleTranslations('en-MW', 'inventory', enInventory);
  },
});
