import { registerModule } from '@kibologic/core';

const importSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`;

registerModule({
  id: 'dataimport',
  name: 'Data Import',
  icon: importSvg,
  tier: 'free',
  sections: [
    { id: 'hub', label: 'Import / Export', page: 'DataImportPage' },
  ],
  actions: [
    { atom: 'inventory.view',   label: 'View Import Hub',   description: 'Access the data import/export hub' },
    { atom: 'inventory.manage', label: 'Import Data',       description: 'Upload Excel files to import or update records' },
    { atom: 'inventory.export', label: 'Export Data',       description: 'Download data as Excel for editing or backup' },
  ],
  async register(app) {
    console.log('[Alpine] DataImport module registered');
  },
});
