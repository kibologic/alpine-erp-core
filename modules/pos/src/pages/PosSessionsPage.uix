import { SwissComponent } from '@swissjs/core';
import { PosService } from '@alpine/core';
import { PageHeader } from '@alpine/ui/src/layout/PageHeader.uix';
import { StatStrip } from '@alpine/ui/src/layout/StatStrip.uix';
import { DataTable } from '@alpine/ui/src/data/DataTable.uix';
import { TextField } from '@alpine/ui/src/form/TextField.uix';
import { StatusBadge } from '@alpine/ui/src/display/StatusBadge.uix';

const columns = [
  { key: 'register_id', label: 'Register', width: '120px' },
  { key: 'status', label: 'Status', width: '120px' },
  { key: 'opened_at', label: 'Opened At', width: '180px' },
  { key: 'closed_at', label: 'Closed At', width: '180px' },
  { key: 'opening_float', label: 'Opening', width: '120px' },
  { key: 'closing_balance', label: 'Closing', width: '120px' }
];

component PosSessionsPage {
  props = {};

  state { let sessions: any[] = []; }
  state { let loading: boolean = true; }
  state { let searchQuery: string = ''; }

  async mounted() {
    this.loading = true;
    try {
      const response = await PosService.getSessions();
      this.sessions = response.data || response || [];
    } catch (e) {
      this.sessions = [];
    } finally {
      this.loading = false;
      this.scheduleUpdate?.();
    }
  }

  getStatusType(status: string) {
    status = (status || '').toLowerCase();
    if (status === 'open' || status === 'active') return 'success';
    if (status === 'closed' || status === 'completed') return 'neutral';
    if (status === 'locked') return 'danger';
    return 'neutral';
  }

  render() {
    const filtered = this.sessions.filter(s => {
      const q = this.searchQuery.toLowerCase();
      return !q || 
             (s.register_id || '').toLowerCase().includes(q) ||
             (s.opened_at || '').toLowerCase().includes(q);
    });

    const updatedColumns = columns.map(col => {
      if (col.key === 'status') {
        return {
          ...col,
          render: (val: string) => <StatusBadge label={val} type={this.getStatusType(val)} />
        };
      }
      if (col.key === 'closed_at') {
        return {
          ...col,
          render: (val: string) => val ? new Date(val).toLocaleString() : <em style="color: var(--color-text-success)">Active</em>
        };
      }
      if (col.key === 'opened_at') {
        return {
          ...col,
          render: (val: string) => val ? new Date(val).toLocaleString() : ''
        };
      }
      return col;
    });

    const openCount = this.sessions.filter(s => s.status === 'open').length;

    return (
      <div class="alp-page">
        <StatStrip 
          stats={[
            { label: "Open Sessions", value: String(openCount) },
            { label: "Total History", value: String(this.sessions.length) },
            { label: "Last Register", value: this.sessions[0]?.register_id || 'N/A' }
          ]}
        />

        <div class="alp-toolbar">
          <div class="alp-toolbar-left">
            <TextField 
              placeholder="Search by register or date..." 
              value={this.searchQuery}
              onchange={(val: string) => { this.searchQuery = val; this.scheduleUpdate?.(); }}
            />
          </div>
        </div>

        <DataTable 
          columns={updatedColumns}
          rows={filtered}
          loading={this.loading}
          searchable={true}
          exportable={true}
          filename="pos_sessions"
          emptyTitle="No sessions found"
          emptyDescription={this.loading ? 'Fetching records...' : 'Open a POS terminal to start a cash session'}
        />
      </div>
    );
  }
}
