import { registerModule, loadModuleTranslations } from '@alpine/core'
import { enPOS } from './locales/en.ui'

const shoppingCartSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>`

registerModule({
  id: 'pos',
  name: 'Point of Sale',
  icon: shoppingCartSvg,
  tier: 'free',
  sections: [
    { id: 'terminal', label: 'Terminal', page: 'PosTerminalPage' },
    { id: 'sales', label: 'Sales', page: 'PosSalesPage' },
    { id: 'customers', label: 'Customers', page: 'PosCustomersPage' },
    { id: 'products', label: 'Products', page: 'PosProductsPage' },
    { id: 'sessions', label: 'Sessions', page: 'PosSessionsPage' },
    { id: 'settings', label: 'Settings', page: 'PosSettingsPage' },
  ],
  actions: [
    { atom: 'pos.sell', label: 'Process Sales', description: 'Process sales at terminal' },
    { atom: 'pos.refund', label: 'Issue Refunds', description: 'Issue refunds on sales' },
    { atom: 'pos.open_session', label: 'Open Sessions', description: 'Open cash register sessions' },
    { atom: 'pos.close_session', label: 'Close Sessions', description: 'Close cash register sessions' },
    { atom: 'pos.view_sales', label: 'View Sales', description: 'View sales history' },
    { atom: 'pos.view_sessions', label: 'View Sessions', description: 'View session history' },
    { atom: 'pos.manage_customers', label: 'Manage Customers', description: 'Create and manage customers' },
  ],
  constraints: {
    maxProducts: 500,
    maxTerminals: 1,
  },
  async register(app) {
    console.log('[Alpine] POS module registered')
    loadModuleTranslations('en-US', 'pos', enPOS)
    loadModuleTranslations('en-MW', 'pos', enPOS) // Support local variance
  },
})
