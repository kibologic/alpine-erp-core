import { api } from './api.ui';

export const PosService = {
  getSessions: () => api.get('/pos/sessions'),
  getCurrentSession: (registerId: string) => api.get(`/pos/sessions/current/${registerId}`),
  openSession: (registerId: string, openingFloat: number, deviceId: string) => 
    api.post('/pos/sessions/open', { register_id: registerId, opening_float: openingFloat, device_id: deviceId }),
  closeSession: (sessionId: string, closingAmount: number) => 
    api.post(`/pos/sessions/close/${sessionId}`, { closing_amount: closingAmount }),
  createSale: (saleData: any) => api.post('/pos/sales', saleData),
  getSale: (saleId: string) => api.get(`/pos/sales/${saleId}`),
  refundSale: (saleId: string) => api.post(`/pos/sales/${saleId}/refund`, {}),

  getSales: (page: number = 1, pageSize: number = 50) =>
    api.get(`/pos/sales?page=${page}&page_size=${pageSize}`),

  getSaleById: (saleId: string) =>
    api.get(`/pos/sales/${saleId}`),

  getCustomers: () =>
    api.get('/inventory/customers'),

  createCustomer: (data: any) =>
    api.post('/inventory/customers', data),

  listTerminals: () =>
    api.get('/pos/terminals'),

  createTerminal: (terminalId: string, name: string, deviceId: string, enabledModes: string[], defaultMode: string) =>
    api.post('/pos/terminals', { terminal_id: terminalId, name, device_id: deviceId, enabled_modes: enabledModes, default_mode: defaultMode }),

  bindTerminalDevice: (terminalId: string, deviceId: string) =>
    api.patch(`/pos/terminals/${terminalId}/bind-device`, { device_id: deviceId }),

  getTerminalConfig: (terminalId: string) =>
    api.get(`/pos/tabs/config/${terminalId}`),

  listTabs: (sessionId: string) =>
    api.get(`/pos/tabs?session_id=${sessionId}`),

  createTab: (name: string, sessionId: string) =>
    api.post('/pos/tabs', { name, session_id: sessionId }),

  getTab: (tabId: string) =>
    api.get(`/pos/tabs/${tabId}`),

  addTabLine: (tabId: string, productId: string, quantity: number) =>
    api.post(`/pos/tabs/${tabId}/lines`, { product_id: productId, quantity }),

  removeTabLine: (tabId: string, lineId: string) =>
    api.delete(`/pos/tabs/${tabId}/lines/${lineId}`),

  closeTab: (tabId: string, paymentMethod: string, amountTendered: number) =>
    api.post(`/pos/tabs/${tabId}/close`, { payment_method: paymentMethod, amount_tendered: amountTendered }),
};

