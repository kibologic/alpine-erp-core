import { SwissComponent } from '@kibologic/core';

component Modal {
  props = {
    open: Boolean,
    title: String,
    size: String,
    onClose: Function as () => void,
    hideClose: Boolean,
    renderBody: Function as () => any,
    renderFooter: Function as () => any,
  };

  mount {
    if (typeof window !== 'undefined') {
      window.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && this.props.open && !this.props.hideClose) {
          this.props.onClose && this.props.onClose();
        }
      });
    }
  }

  handleBackdropClick() {
    if (!this.props.hideClose) {
      this.props.onClose && this.props.onClose();
    }
  }

  render() {
    if (typeof document !== 'undefined') {
      document.body.style.overflow = this.props.open ? 'hidden' : '';
    }

    if (!this.props.open) return null;

    const size = this.props.size || 'md';

    return (
      <div
        class="alp-modal-backdrop"
        onclick={() => this.handleBackdropClick()}
        role="dialog"
        aria-modal="true"
        aria-label={this.props.title || 'Dialog'}
      >
        <div
          class={`alp-modal alp-modal--${size}`}
          onclick={(e: Event) => e.stopPropagation()}
        >
          <div class="alp-modal-header">
            <h2 class="alp-modal-title">{this.props.title || ''}</h2>
            {!this.props.hideClose ? (
              <button
                type="button"
                class="alp-modal-close"
                onclick={() => this.props.onClose && this.props.onClose()}
                aria-label="Close dialog"
              >✕</button>
            ) : null}
          </div>

          <div class="alp-modal-body">
            {this.props.renderBody ? this.props.renderBody() : null}
          </div>

          {this.props.renderFooter ? (
            <div class="alp-modal-footer">
              {this.props.renderFooter()}
            </div>
          ) : null}
        </div>
      </div>
    );
  }
}
