import { SwissComponent } from '@kibologic/core';

component Select {
  props = {
    options: Array as () => Array<{ value: string; label: string; disabled?: boolean }>,
    value: String,
    placeholder: String,
    size: String,
    disabled: Boolean,
    error: String,
    label: String,
    searchable: Boolean,
    onChange: Function as (value: string) => void,
  };

  state { let searchText: string = ''; }
  state { let open: boolean = false; }

  toggle() {
    if (this.props.disabled) return;
    this.open = !this.open;
    this.scheduleUpdate?.();
  }

  close() {
    this.open = false;
    this.searchText = '';
    this.scheduleUpdate?.();
  }

  selectOption(val: string) {
    this.close();
    if (this.props.onChange) this.props.onChange(val);
  }

  handleSearch(e: Event) {
    this.searchText = (e.target as HTMLInputElement).value;
    this.scheduleUpdate?.();
  }

  render() {
    const size = this.props.size || 'md';
    const isDisabled = !!this.props.disabled;
    const hasError = !!(this.props.error);
    const options = Array.isArray(this.props.options) ? this.props.options : [];
    const searchable = !!this.props.searchable;

    const q = (this.searchText || '').toLowerCase();
    const filtered = searchable && q
      ? options.filter((o) => o.label.toLowerCase().includes(q))
      : options;

    const selected = options.find((o) => o.value === this.props.value);
    const displayLabel = selected ? selected.label : (this.props.placeholder || 'Select…');

    return (
      <div class={`alp-field${isDisabled ? ' alp-field--disabled' : ''}${hasError ? ' alp-field--error' : ''}`}>
        {this.props.label ? (
          <label class="alp-field-label">{this.props.label}</label>
        ) : null}
        <div class={`alp-select alp-select--${size}${this.open ? ' alp-select--open' : ''}${hasError ? ' alp-select--error' : ''}${isDisabled ? ' alp-select--disabled' : ''}`}>
          <button
            type="button"
            class="alp-select-trigger"
            disabled={isDisabled}
            onclick={() => this.toggle()}
            aria-haspopup="listbox"
            aria-expanded={this.open ? 'true' : 'false'}
          >
            <span class={`alp-select-value${!selected ? ' alp-select-placeholder' : ''}`}>
              {displayLabel}
            </span>
            <span class="alp-select-caret" aria-hidden="true">▾</span>
          </button>

          {this.open ? (
            <div class="alp-select-dropdown" role="listbox">
              {searchable ? (
                <div class="alp-select-search">
                  <input
                    type="text"
                    class="alp-select-search-input"
                    placeholder="Search…"
                    value={this.searchText}
                    oninput={(e: Event) => this.handleSearch(e)}
                    onclick={(e: Event) => e.stopPropagation()}
                  />
                </div>
              ) : null}
              {filtered.length === 0 ? (
                <div class="alp-select-empty">No options</div>
              ) : (
                filtered.map((opt) => (
                  <button
                    type="button"
                    class={`alp-select-option${opt.value === this.props.value ? ' alp-select-option--selected' : ''}${opt.disabled ? ' alp-select-option--disabled' : ''}`}
                    role="option"
                    aria-selected={opt.value === this.props.value ? 'true' : 'false'}
                    disabled={!!opt.disabled}
                    onclick={() => !opt.disabled && this.selectOption(opt.value)}
                  >
                    {opt.label}
                  </button>
                ))
              )}
            </div>
          ) : null}
        </div>
        {hasError ? (
          <span class="alp-field-error">{this.props.error}</span>
        ) : null}
      </div>
    );
  }
}
