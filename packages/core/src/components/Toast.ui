import { SwissComponent } from '@kibologic/core';

component Toast {
  props = {
    message: String,
    variant: String,
    duration: Number,
    onDismiss: Function as () => void,
  };

  state { let visible: boolean = true; }

  mount {
    const duration = this.props.duration || 4000;
    setTimeout(() => {
      this.visible = false;
      this.scheduleUpdate?.();
      if (this.props.onDismiss) this.props.onDismiss();
    }, duration);
  }

  dismiss() {
    this.visible = false;
    this.scheduleUpdate?.();
    if (this.props.onDismiss) this.props.onDismiss();
  }

  variantIcon(variant: string): string {
    if (variant === 'success') return '✓';
    if (variant === 'warning') return '⚠';
    if (variant === 'error') return '✕';
    return 'ℹ';
  }

  render() {
    if (!this.visible) return null;

    const variant = this.props.variant || 'info';

    return (
      <div class={`alp-toast alp-toast--${variant}`} role="alert" aria-live="assertive">
        <span class="alp-toast-icon" aria-hidden="true">{this.variantIcon(variant)}</span>
        <span class="alp-toast-message">{this.props.message || ''}</span>
        <button
          type="button"
          class="alp-toast-dismiss"
          onclick={() => this.dismiss()}
          aria-label="Dismiss"
        >✕</button>
      </div>
    );
  }
}
