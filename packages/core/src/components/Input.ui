import { SwissComponent } from '@kibologic/core';

component Input {
  props = {
    type: String,
    size: String,
    placeholder: String,
    value: String,
    disabled: Boolean,
    error: String,
    label: String,
    helperText: String,
    prefix: String,
    clearable: Boolean,
    onChange: Function as (value: string) => void,
  };

  state { let internalValue: string = ''; }

  mount {
    this.internalValue = this.props.value || '';
  }

  handleInput(e: Event) {
    const val = (e.target as HTMLInputElement).value;
    this.internalValue = val;
    this.scheduleUpdate?.();
    if (this.props.onChange) this.props.onChange(val);
  }

  handleClear() {
    this.internalValue = '';
    this.scheduleUpdate?.();
    if (this.props.onChange) this.props.onChange('');
  }

  render() {
    const type = this.props.type || 'text';
    const size = this.props.size || 'md';
    const isDisabled = !!this.props.disabled;
    const hasError = !!(this.props.error);
    const hasPrefix = !!(this.props.prefix);
    const clearable = !!this.props.clearable;

    return (
      <div class={`alp-field${isDisabled ? ' alp-field--disabled' : ''}${hasError ? ' alp-field--error' : ''}`}>
        {this.props.label ? (
          <label class="alp-field-label">{this.props.label}</label>
        ) : null}
        <div class={`alp-input-wrap alp-input-wrap--${size}${hasPrefix ? ' alp-input-wrap--prefix' : ''}${clearable ? ' alp-input-wrap--clearable' : ''}`}>
          {hasPrefix ? (
            <span class="alp-input-prefix">{this.props.prefix}</span>
          ) : null}
          <input
            type={type}
            class={`alp-input alp-input--${size}${hasError ? ' alp-input--error' : ''}`}
            placeholder={this.props.placeholder || ''}
            value={this.internalValue}
            disabled={isDisabled}
            oninput={(e: Event) => this.handleInput(e)}
          />
          {clearable && this.internalValue ? (
            <button
              type="button"
              class="alp-input-clear"
              onclick={() => this.handleClear()}
              aria-label="Clear"
            >✕</button>
          ) : null}
        </div>
        {hasError ? (
          <span class="alp-field-error">{this.props.error}</span>
        ) : null}
        {this.props.helperText && !hasError ? (
          <span class="alp-field-helper">{this.props.helperText}</span>
        ) : null}
      </div>
    );
  }
}
