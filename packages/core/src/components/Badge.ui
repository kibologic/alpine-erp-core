import { SwissComponent } from '@kibologic/core';

component Badge {
  props = {
    variant: String,
    size: String,
    dot: Boolean,
    label: String,
  };

  render() {
    const variant = this.props.variant || 'neutral';
    const size = this.props.size || 'md';
    const dot = !!this.props.dot;

    return (
      <span class={`alp-badge alp-badge--${variant} alp-badge--${size}`}>
        {dot ? (
          <span class={`alp-badge-dot alp-badge-dot--${variant}`} aria-hidden="true"></span>
        ) : null}
        {this.props.label || ''}
      </span>
    );
  }
}
