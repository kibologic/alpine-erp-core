import { SwissComponent } from '@kibologic/core';

component StatusBadge {
  props = {
    label: String,
    type: String, // success, warning, danger, info, neutral
  };

  render() {
    const type = this.props.type || 'neutral';
    
    // Sleek, minimal variant mapping directly to design tokens
    return (
      <span class={`alp-badge alp-badge--${type}`}>
        {this.props.label}
      </span>
    );
  }
}
