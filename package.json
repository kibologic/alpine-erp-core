{
  "name": "alpine-erp-core",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "@alpine/ui": "link:../alpine-ui/packages/ui",
