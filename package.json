      "@swissjs/swite": "link:../swite",
      "@swissjs/components": "link:../swiss-lib/packages/components",
      "@swissjs/plugin-web-storage": "link:../swiss-lib/packages/plugins/web-storage",
      "@swissjs/security": "link:../swiss-lib/packages/security",
      "@swissjs/router": "link:../swiss-lib/packages/router",
      "@swissjs/utils": "link:../swiss-lib/packages/utils",
