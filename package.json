      "@kibologic/web-storage": "latest",
      "@kibologic/shared-types": "latest",
      "@kibologic/shared-utils": "latest",
      "@kibologic/theme": "latest",
      "@kibologic/event-bus": "latest",
      "@kibologic/contracts": "latest",
      "@kibologic/connectivity": "latest",
      "@kibologic/payments": "latest",
      "@kibologic/telemetry": "latest",
      "@kibologic/i18n": "latest",
